# OpenRouter API Configuration
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_DEV=deepseek/deepseek-v3-base:free
OPENROUTER_MODEL_EVAL=anthropic/claude-3.5-sonnet

# HubSpot Configuration
HUBSPOT_API_KEY=your_hubspot_api_key_here
HUBSPOT_APP_ID=your_app_id_here

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=hello@tenacious-ai.com
RESEND_WEBHOOK_SECRET=your_webhook_secret

# Africa's Talking SMS
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_SHORT_CODE=12345

# Cal.com Configuration
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_EVENT_TYPE_ID=123456
CALCOM_BASE_URL=http://localhost:3000

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=your_public_key
LANGFUSE_SECRET_KEY=your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# Database (if using)
DATABASE_URL=sqlite:///./data/tenacious.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/tenacious.log

# Kill switch (default: False means send to staff sink)
SEND_TO_REAL_PROSPECTS=False

# Evaluation
TAU2_BENCH_HELD_OUT_SEED=42
EVALUATION_TEMPERATURE=0.1
